# ===== Telegram =====
# Токен бота из @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Публичный HTTPS-домен (на него указывает A-запись DNS вашего VPS)
PUBLIC_DOMAIN=challenge.example.com
# URL Web App (обычно = https://<PUBLIC_DOMAIN>)
WEBAPP_URL=https://challenge.example.com

# Режим получения апдейтов: true = webhook (прод), false = long polling (локально)
USE_WEBHOOK=true
# Секрет для проверки webhook (любая случайная строка)
WEBHOOK_SECRET=change-me-to-random-string
# Необязательно: полный URL webhook (по умолчанию https://<PUBLIC_DOMAIN>/webhook)
# WEBHOOK_URL=https://challenge.example.com/webhook

# Telegram ID администраторов через запятую (узнать свой: напишите боту @userinfobot)
ADMIN_TELEGRAM_IDS=11111111,22222222

# ===== База данных =====
POSTGRES_PASSWORD=challenge
DATABASE_URL=postgresql://challenge:challenge@db:5432/challenge

# ===== Прочее =====
TZ=Europe/Moscow
PORT=3000
NODE_ENV=production

# Дата старта челленджа при первом сидировании (YYYY-MM-DD). По умолчанию — сегодня.
# CHALLENGE_START_DATE=2026-06-15

# Короткое имя Mini App из BotFather (/newapp). Если задано — ссылка запуска вида
# https://t.me/<bot>/<MINIAPP_SHORT_NAME>. Если пусто — используется ?startapp у Main Mini App.
# MINIAPP_SHORT_NAME=app
